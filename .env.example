# Google AI (Gemini) — required for AI analysis features
GOOGLE_API_KEY=your_google_api_key_here

# Google PageSpeed Insights — optional, improves CWV rate limits
PAGESPEED_API_KEY=your_pagespeed_api_key_here

# Ngrok tunnel — only needed for local Docker+ngrok setup (not needed on Vercel)
NGROK_AUTHTOKEN=your_ngrok_authtoken_here
NGROK_DOMAIN=your-domain.ngrok-free.dev

# SEO Data API (moveupx) — GSC + Ahrefs data
SEO_API_KEY=your_seo_api_key_here

# Scraper settings
PROXY_URL=
SCRAPER_SLEEP_MIN=3
SCRAPER_SLEEP_MAX=7

# ── Vercel deployment ─────────────────────────────────────────────────────────
# Google OAuth credentials (base64-encoded, for serverless environments)
# Generate TOKEN_PICKLE_B64:  python -c "import base64; print(base64.b64encode(open('token.pickle','rb').read()).decode())"
# Generate CLIENT_SECRET_JSON: paste the full one-line content of client_secret.json
TOKEN_PICKLE_B64=
CLIENT_SECRET_JSON=
