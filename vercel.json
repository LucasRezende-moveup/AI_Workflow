{
  "framework": null,
  "buildCommand": "cd frontend && npm install && npm run build",
  "outputDirectory": "frontend/dist",
  "functions": {
    "api/index.py": { "maxDuration": 300 }
  },
  "crons": [
    { "path": "/api/cron/check-all", "schedule": "0 8 * * *" },
    { "path": "/api/cron/seo-health-snapshot", "schedule": "0 7 * * *" }
  ],
  "routes": [
    { "src": "/api(.*)", "dest": "/api/index.py" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
